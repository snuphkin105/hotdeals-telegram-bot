# Required secrets
TELEGRAM_BOT_TOKEN=replace_me
ALIEXPRESS_APP_KEY=replace_me
ALIEXPRESS_APP_SECRET=replace_me
ALIEXPRESS_TRACKING_ID=telegram_bot

# Product/search settings
DEFAULT_CURRENCY=USD
DEFAULT_LANGUAGE=EN
PRODUCTS_COUNT=3
CANDIDATE_COUNT=50
CACHE_TTL_SECONDS=600
REQUEST_COOLDOWN_SECONDS=3
LOG_LEVEL=INFO

# Render automatically provides RENDER_EXTERNAL_URL and PORT.
# Set FORCE_POLLING=true only when running locally without a public URL.
FORCE_POLLING=false
# Optional. If omitted, a safe value is derived from the Telegram token.
WEBHOOK_SECRET=
# Optional outside Render, e.g. https://your-service.example.com
WEBHOOK_BASE_URL=
